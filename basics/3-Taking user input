package com.company;
import java.util.Scanner;

public class taking_input {
    public static void main (String[] args) {
        System.out.println("Taking input from user");

        Scanner sc = new Scanner(System.in);

        System.out.println("Enter number 1:");
        int a = sc.nextInt();

        System.out.println("Enter number 2:");
        int b = sc.nextInt();
        int sum = a + b;

        System.out.println("The sum of numbers are");
        System.out.println(sum);

        //to check whether user input value is int or not
        Boolean b1 = sc.hasNextInt();
        System.out.println(b1);

        //when u do sc.next() in string, it only print the 1st word of that sentence
        // when u use sc.nextLine(), it print all sentence

        String str = sc.next();
        System.out.println(str);

        String str = sc.nextLine();
        System.out.println(str);
    }
}
